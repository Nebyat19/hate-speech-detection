DATABASE_URL="file:./dev.db"
PORT=3001
CLIENT_ORIGIN=http://localhost:5173

# Display name for logs, emails (subject / default EMAIL_FROM), and API `appName` field
APP_NAME=Safetext

# Moderation: local (default, no API key) | openai | google-perspective | custom-amharic
MODERATION_PROVIDER=local
# ONNX model for local provider — implementation lives in packages/local-moderation/
LOCAL_MODERATION_MODEL=Xenova/toxic-bert
# Optional: cache dir for model files
# TRANSFORMERS_CACHE=/path/to/cache

# OpenAI (only if MODERATION_PROVIDER=openai)
OPENAI_API_KEY=
MODERATION_MODEL=text-moderation-latest

# Strikes & behavior
MAX_STRIKES=3
MODERATION_FLAG_THRESHOLD=0.5
EMAIL_ENABLED=true
MUTE_ON_ESCALATION=false

# OpenAI-only (429 / burst protection when using OpenAI)
OPENAI_MOD_MAX_ATTEMPTS=6
OPENAI_MOD_RETRY_CAP_MS=60000
MOD_MIN_SEND_INTERVAL_MS=800

# Public classifier API (POST /v1/moderate) — uses local ONNX model always
# Leave empty for open demo; in production set comma-separated keys
PUBLIC_API_KEYS=
PUBLIC_API_MAX_TEXT_CHARS=8000
PUBLIC_API_RATE_WINDOW_MS=60000
PUBLIC_API_RATE_MAX=120
# true = any browser Origin may call /v1; set false and use PUBLIC_API_CORS_ORIGINS
PUBLIC_API_CORS_ALLOW_ALL=true
# When CORS allow-all is false: extra origins in addition to CLIENT_ORIGIN
PUBLIC_API_CORS_ORIGINS=

# Nodemailer (optional; uses console fallback if incomplete)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MODERATOR_EMAIL=moderator@example.com
# Optional; default is "${APP_NAME} <noreply@localhost.local>"
EMAIL_FROM=My App <noreply@example.com>
